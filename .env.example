# ── Core ─────────────────────────────────────────────────
DATABASE_URL=postgres://opencrow:opencrow@127.0.0.1:5432/opencrow
QDRANT_URL=http://127.0.0.1:6333

# ── db_query least-privilege role ────────────────────────
# Required for the db_query agent tool. Without this the tool refuses to run
# (fail-closed). Create the role first via migration 022_readonly_role.sql:
#
#   CREATE ROLE opencrow_readonly WITH LOGIN PASSWORD 'choose-a-strong-password';
#   -- then run migrations to apply GRANTs and REVOKEs
#
# This connection authenticates as the read-only role so the DB layer enforces
# access control regardless of what the agent sends as SQL.
OPENCROW_READONLY_DATABASE_URL=postgres://opencrow_readonly:CHANGE_ME@127.0.0.1:5432/opencrow

# ── Security ─────────────────────────────────────────────
OPENCROW_WEB_TOKEN=your-secret-token-here
OPENCROW_INTERNAL_TOKEN=your-internal-token-here

# ── Web Server ───────────────────────────────────────────
OPENCROW_WEB_HOST=127.0.0.1

# ── AI Providers ─────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-...
ALIBABA_API_KEY=sk-...
ALIBABA_BASE_URL=https://coding-intl.dashscope.aliyuncs.com/apps/anthropic
VOYAGE_API_KEY=pa-...

# mem0 sidecar extraction LLM (see docker-compose mem0 service). Default is now
# LOCAL Ollama (gemma4:e2b-it-qat) — $0, no key needed. HOST PREREQUISITE:
#   ollama pull gemma4:e2b-it-qat
# (the host must run Ollama; it already serves nomic-embed-text for embeddings.
#  Use the QAT 4-bit build — ~4.3GB resident — the 7GB default swap-thrashes a
#  24GB host. Recommended host env: OLLAMA_NUM_PARALLEL=1.)
# Reasoning models stall mem0's always-on graph extraction — use a non-reasoning,
# native-function-calling model. MEM0_LLM_API_KEY is only needed if you switch
# the docker-compose mem0 service back to the hosted GLM fallback.
# MEM0_LLM_API_KEY=sk-...   # only for the hosted GLM fallback

# ── Telegram ─────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
TELEGRAM_ALLOWED_USER_IDS=


# Smart idea-pipeline feature flags (optional; default off)
# Enable the LLM signal categorization+ranking layer at ingest and calibrated
# importance-filtered RAG retrieval.
# OPENCROW_SMART_SIGNAL_FACETS=true
# OPENCROW_SMART_SIGNAL_RANKING=true
# OPENCROW_SMART_SIGNAL_IMPORTANCE_FLOOR=low

# Headless/container auth for the direct Anthropic chat path (from `claude setup-token`).
# Takes precedence over ~/.claude/.credentials.json (absent in Docker/CI).
# CLAUDE_CODE_OAUTH_TOKEN=
