# ── Core ─────────────────────────────────────────────────
DATABASE_URL=postgres://opencrow:opencrow@127.0.0.1:5432/opencrow
QDRANT_URL=http://127.0.0.1:6333

# ── Security ─────────────────────────────────────────────
OPENCROW_WEB_TOKEN=your-secret-token-here
OPENCROW_INTERNAL_TOKEN=your-internal-token-here

# ── Web Server ───────────────────────────────────────────
OPENCROW_WEB_HOST=127.0.0.1

# ── AI Providers ─────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-...
ALIBABA_API_KEY=sk-...
ALIBABA_BASE_URL=https://coding-intl.dashscope.aliyuncs.com/apps/anthropic
VOYAGE_API_KEY=pa-...

# ── Telegram ─────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
TELEGRAM_ALLOWED_USER_IDS=

# ── Time-Series (QuestDB) ───────────────────────────────
QUESTDB_ILP_URL=tcp::addr=127.0.0.1:9009
QUESTDB_HTTP_URL=http://127.0.0.1:9000

# ── ProductHunt (https://producthunt.com/v2/oauth/applications)
PH_API_TOKEN=
PH_API_SECRET=
